#!/usr/bin/env bash
# Pre-push hook for sage-docs
#
# Policy:
#   - main is the default branch
#   - Block direct push to main
#   - Use feature/* branches and PR into main for larger changes
#   - Never run package publish/build logic in docs repo

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

while read -r local_ref _ remote_ref _; do
    if [ "$local_ref" = "refs/heads/main" ] || [ "$remote_ref" = "refs/heads/main" ]; then
        echo -e "${RED}✗ Direct push to main is forbidden${NC}"
        echo -e "${YELLOW}  Please push to a feature branch, then open a PR into main.${NC}"
        exit 1
    fi
done

echo -e "${GREEN}✓ pre-push checks passed (main default, feature branch PR flow)${NC}"
exit 0
